{
  "name": "my-app",
  "main": "client/index.js",
  "version": "1.0.0",
  "scripts": {
    "expo:dev": "npx expo start --no-dev --minify --tunnel --clear --go",
    "server:dev": "npx tsx server/index.ts",
    "dev": "npm run server:dev ; npm run expo:dev",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "node server_dist/index.js",
    "db:push": "drizzle-kit push && npx tsx scripts/seed.ts",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:reset": "node scripts/reset-db.js",
    "db:setup": "node scripts/reset-db.js ; npm run db:push",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "check:types": "tsc --noEmit",
    "check:format": "prettier --check \"**/*.{js,ts,tsx,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\"",
    "ngrok": "ngrok http 5000"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
